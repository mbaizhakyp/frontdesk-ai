# Copy to .env.local and fill in. Never commit real keys.

# Supabase (Project Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Twilio (Console). Production SMS requires A2P 10DLC registration.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Voice AI (Vapi or Retell)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Cal.com (booking)
CALCOM_API_KEY=

# Protects the follow-up cron endpoint
CRON_SECRET=
